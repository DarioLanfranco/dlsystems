---
import NavLogo from './NavLogo.astro'
import NavLinks from './NavLinks.astro'
import OnlineIndicator from './OnlineIndicator.astro'
import MobileMenu from './MobileMenu.astro'
import MobileMenuButton from './MobileMenuButton.astro'
---

<nav class="relative z-50 flex items-center justify-between px-8 py-5 max-w-7xl mx-auto border-b border-gray-100/80">
  <NavLogo />

  <div class="hidden md:flex items-center gap-8">
    <NavLinks />
  </div>

  <div class="hidden md:flex">
    <OnlineIndicator />
  </div>

  <div class="flex md:hidden items-center gap-4">
    <OnlineIndicator />
    <MobileMenuButton />
  </div>
</nav>

<MobileMenu>
  <div class="flex items-center justify-between px-8 py-5">
    <NavLogo />
    <div class="flex md:hidden">
      <OnlineIndicator />
    </div>
    <button data-menu-close class="md:hidden p-2 text-gray-500 hover:text-gray-900 transition-colors" aria-label="Cerrar menú">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" d="M6 6l12 12" />
        <path stroke-linecap="round" d="M18 6l-12 12" />
      </svg>
    </button>
  </div>

  <div class="flex-1 flex flex-col items-center justify-center gap-10 px-8">
    <a href="/" class="text-3xl md:text-4xl font-bold text-gray-900 hover:text-blue-600 transition-colors">Inicio</a>
    <a href="/proyectos" class="text-3xl md:text-4xl font-bold text-gray-900 hover:text-blue-600 transition-colors">Proyectos</a>
    <a href="/lab" class="text-3xl md:text-4xl font-bold text-gray-900 hover:text-blue-600 transition-colors">Lab</a>
    <a href="/contacto" class="text-3xl md:text-4xl font-bold text-gray-900 hover:text-blue-600 transition-colors">Contacto</a>
  </div>
</MobileMenu>

<script src="../../scripts/navbar.js"></script>
