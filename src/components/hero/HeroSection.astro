---
import HeroTitle from './HeroTitle.astro'
import HeroSubtitle from './HeroSubtitle.astro'
import HeroActions from './HeroActions.astro'
---

<section class="px-8 py-20 max-w-7xl mx-auto">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="flex flex-col gap-8">
      <HeroTitle />
      <HeroSubtitle />
      <HeroActions />
    </div>
    <div class="flex flex-col gap-6">
      <slot name="widgets" />
    </div>
  </div>
</section>
